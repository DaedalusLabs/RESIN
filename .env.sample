# Production endpoints (uncomment for production)
# BACKEND_ENDPOINT=https://api.example.com
# IMAGES_BASE_URL=https://api.example.com
# TYPESENSE_HOST=api.example.com
# TYPESENSE_PORT=443
# TYPESENSE_API_KEY=your_typesense_api_key_here

# Development endpoints
BACKEND_ENDPOINT=https://api.resin.estate
IMAGES_BASE_URL=https://files.resin.estate
TYPESENSE_HOST=api.resin.estate
TYPESENSE_PORT=443
TYPESENSE_API_KEY=your_development_api_key
TYPESENSE_PROTOCOL=https
# for development you probably want to use the local typesense instance
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8109
# TYPESENSE_API_KEY=your_development_api_key
# TYPESENSE_PROTOCOL=http

# Nostr configuration
MESSAGES_PUBKEY=your_messages_pubkey_here
PUBKEY_WHITELIST=pubkey1,pubkey2,pubkey3

# Payment configuration
BTCPAY_BASE_URL=https://btcpay.example.com